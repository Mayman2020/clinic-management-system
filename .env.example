# Clinic System — Docker Compose environment
# Copy to .env and set strong values before: docker compose up --build

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-use-a-strong-password
POSTGRES_DB=postgres

# Minimum 32 characters — generate with: openssl rand -base64 48
JWT_SECRET=change-me-generate-a-long-random-jwt-secret-min-32-chars

# Comma-separated CORS origin patterns (required in prod profile)
# Example: https://clinic.example.com,https://admin.clinic.example.com
CORS_ALLOWED_ORIGINS=https://localhost:4200

# Optional — password reset link base (no trailing slash)
PASSWORD_RESET_BASE_URL=http://localhost:4310/auth/reset-password

# Optional — SMTP (set MAIL_ENABLED=true to send real emails)
MAIL_ENABLED=false
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@clinic.local
